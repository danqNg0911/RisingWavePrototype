COMPOSE_PROJECT_NAME=risingwave-ai-rpa
REDPANDA_IMAGE=redpandadata/redpanda:v25.1.2
RISINGWAVE_IMAGE=risingwavelabs/risingwave:v2.8.3-aa2cf138
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_BOOTSTRAP_SERVERS_HOST=localhost:9092
RISINGWAVE_DSN=postgresql://root@risingwave:4566/dev
RISINGWAVE_DSN_HOST=postgresql://root@localhost:4566/dev
EVENTS_PER_SECOND=20
RUN_SECONDS=180
GENERATOR_SEED=4242
AI_MODE=hf_api
HF_TOKEN=
HF_MODEL_ID=facebook/bart-large-mnli
HF_PROVIDER_POLICY=preferred
RISK_THRESHOLD_WARNING=0.60
RISK_THRESHOLD_NOTIFY=0.75
RISK_THRESHOLD_BLOCK=0.90
RPA_MODE=openflow_queue
OPENFLOW_URL=grpc://grpc.app.openiap.io:443
OPENFLOW_USERNAME=
OPENFLOW_PASSWORD=
OPENFLOW_TOKEN=
OPENRPA_QUEUE_NAME=risingwave_rpa_decisions
OPENRPA_ENTRY_WORKFLOW=
OPENFLOW_MAX_DISPATCH_RETRIES=6
OPENFLOW_BACKLOG_BATCH_SIZE=3
